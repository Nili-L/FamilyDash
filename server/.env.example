# Google OAuth2 credentials (required for calendar integration)
# IMPORTANT:
# - GOOGLE_REDIRECT_URI must exactly match the redirect URI in Google Cloud Console
# - In production, use HTTPS for GOOGLE_REDIRECT_URI and FRONTEND_URL
# - Never commit GOOGLE_CLIENT_SECRET to version control
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Shared family password for app login (required)
# Use a strong password (12+ characters, mixed case, numbers, symbols)
APP_PASSWORD=

# AES-256 encryption key for OAuth tokens at rest (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# CORS allowed origins (comma-separated, required in production)
CORS_ORIGINS=http://localhost:5173

# Set to "production" in production to enable Secure cookie flag
# NODE_ENV=production
